[
  {
    "language": "AsciiDoc",
    "extensions": [
      ".adoc",
      ".asc",
      ".asciidoc"
    ],
    "markers": [
      {
        "type": "line",
        "pattern": "//"
      },
      {
        "type": "block",
        "pattern": {
          "start": "////",
          "end": "////"
        }
      }
    ]
  }
]
